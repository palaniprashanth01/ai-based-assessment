# Get free Groq API keys (no credit card) from https://console.groq.com/keys
# Primary key (required).
GROQ_API_KEY=

# Optional additional keys for TPM rotation. The function tries each key in
# turn when one hits a tokens-per-minute rate limit, so N keys ≈ N× free-tier
# throughput. You can create multiple keys under the same Groq account.
# GROQ_API_KEY_2=
# GROQ_API_KEY_3=
# GROQ_API_KEY_4=
# GROQ_API_KEY_5=
